<!-- AddHonorPage.xaml -->
<Page x:Class="Genio.AddHonorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="AddHonorPage"
      Background="{StaticResource WindowBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК -->
        <TextBlock Grid.Row="0"
                   Text="Добавление на доску почета"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource LightTextColor}"
                   Margin="30,15,20,10"
                   HorizontalAlignment="Left"/>

        <!-- ОСНОВНОЙ КОНТЕНТ - СПИСОК СТУДЕНТОВ И ДАТА -->
        <Border Grid.Row="1"
                Background="{StaticResource ReportFrameColor}"
                CornerRadius="8"
                Margin="20,0,20,15"
                Style="{StaticResource HoverFrameStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ШАПКА С ПОИСКОМ И ДАТОЙ -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        Margin="15,15,15,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- ПОЛЕ ПОИСКА -->
                        <Border Grid.Column="0"
                                Background="{StaticResource MenuItemHoverColor}"
                                CornerRadius="12"
                                Height="35"
                                Margin="0,0,10,0">
                            <Grid>
                                <TextBox x:Name="StudentSearchTextBox"
                                         Background="Transparent"
                                         Foreground="{StaticResource LightTextColor}"
                                         BorderThickness="0"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         CaretBrush="White"
                                         Padding="38,0,10,0"
                                         VerticalAlignment="Center"
                                         Text="Поиск..."
                                         MaxLength="200"/>
                                <Image Source="/Images/searchIcon.png"
                                       Width="20"
                                       Height="20"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Stretch="Uniform"/>
                            </Grid>
                        </Border>

                        <!-- ДАТА ЗАНЕСЕНИЯ -->
                        <Border Grid.Column="1"
                                Background="{StaticResource MenuItemHoverColor}"
                                CornerRadius="8"
                                Height="35"
                                Width="180"
                                Margin="0,0,10,0">
                            <Grid>
                                <TextBox x:Name="PlacementDateTextBox"
                                         Background="{StaticResource MenuItemHoverColor}"
                                         Foreground="{StaticResource LightTextColor}"
                                         BorderThickness="0"
                                         Padding="12,0,35,0"
                                         VerticalAlignment="Center"
                                         FontSize="14"
                                         IsReadOnly="True"/>
                                <Button x:Name="PlacementDateButton"
                                        Style="{StaticResource DatePickerButtonStyle}"
                                        HorizontalAlignment="Right"
                                        Width="35"
                                        Height="35">
                                    <Image Source="{StaticResource DatePickerIcon}"
                                           Width="18"
                                           Height="18"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- СПИСОК УЧАЩИХСЯ - ✅ ИСПРАВЛЕНО: добавлен CustomScrollViewerStyle -->
                <ScrollViewer Grid.Row="1"
                              Style="{StaticResource CustomScrollViewerStyle}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="15,0,15,15">
                    <StackPanel x:Name="StudentsList">
                        <!-- Список студентов будет заполняться динамически -->
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ПОДВАЛ С КНОПКАМИ -->
        <Border Grid.Row="2"
                Background="Transparent"
                Margin="20,0,20,20"
                Height="60">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <!-- КНОПКА НАЗАД -->
                <Button x:Name="BackButton"
                        Style="{StaticResource PurpleCircleButtonStyle}"
                        Width="35"
                        Height="35"
                        Margin="0,0,10,0">
                    <Image Source="/Images/backIcon.png"
                           Width="24"
                           Height="24"
                           Stretch="Uniform"/>
                </Button>
                <!-- КНОПКА СОХРАНИТЬ ЗАПИСЬ -->
                <Button x:Name="SaveButton"
                        Style="{StaticResource PurpleCircleButtonStyle}"
                        Width="35"
                        Height="35"
                        Margin="0,0,10,0">
                    <Image Source="/Images/saveIcon.png"
                           Width="20"
                           Height="20"
                           Stretch="Uniform"/>
                </Button>
                <!-- КНОПКА УДАЛИТЬ ЗАПИСЬ -->
                <Button x:Name="DeleteButton"
                        Style="{StaticResource CircleButtonStyle}"
                        Width="36"
                        Height="38"
                        Visibility="Collapsed">
                    <Image Source="/Images/iconRemove.png"
                           Width="17"
                           Height="17"
                           Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- КАЛЕНДАРЬ ДЛЯ ДАТЫ -->
        <Popup x:Name="DatePickerPopup"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Slide"
               VerticalOffset="5">
            <Border Background="{StaticResource CalendarBackground}"
                    BorderBrush="{StaticResource AccentColor}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="8">
                <Calendar x:Name="DatePickerCalendar"
                          SelectionMode="SingleDate"/>
            </Border>
        </Popup>
    </Grid>
</Page>