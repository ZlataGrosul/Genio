<!-- CustomMessageBox.xaml -->
<Window x:Class="Genio.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource CustomMessageBoxWindowStyle}"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

    <Border Style="{StaticResource MessageBoxContainerStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,5,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="IconImage" 
                       Grid.Column="0"
                       Style="{StaticResource MessageBoxIconStyle}"/>

                <TextBlock x:Name="TitleText" 
                           Grid.Column="1"
                           Style="{StaticResource MessageBoxTitleStyle}"
                           VerticalAlignment="Center"
                           Margin="10"/>
            </Grid>

            <TextBlock x:Name="MessageText" 
                       Grid.Row="1"
                       Style="{StaticResource MessageBoxMessageStyle}"/>

            <StackPanel x:Name="ButtonsPanel" 
                        Grid.Row="2"
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,5,0,0"/>
        </Grid>
    </Border>
</Window>