<Page x:Class="Genio.AnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      Title="AnalyticsPage"
      Background="{StaticResource WindowBackground}"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Стиль для столбцов диаграммы -->
        <Style x:Key="ChartColumnStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource StudentCardBrush1}"/>
            <Setter Property="CornerRadius" Value="4,4,0,0"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF5045D5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для секторов круговой диаграммы -->
        <Style x:Key="PieSliceStyle" TargetType="Path">
            <Setter Property="Stroke" Value="{StaticResource ReportFrameColor}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для заголовков фреймов -->
        <Style x:Key="FrameTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LightTextColor}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль для ссылок -->
        <Style x:Key="LinkTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF5045D5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для элементов легенды -->
        <Style x:Key="LegendItemStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <!-- Стиль для легенды месяцев -->
        <Style x:Key="MonthLegendStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>

        <!-- Стиль для текста легенды специальностей -->
        <Style x:Key="SpecializationLegendTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LightTextColor}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="MaxWidth" Value="280"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Style="{StaticResource CustomScrollViewerStyle}">
        <Grid Margin="20,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- ШАПКА С ДАТОЙ -->
            <Grid Grid.Row="0" Grid.ColumnSpan="3"
                  Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Аналитика"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource LightTextColor}"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="CurrentDateText"
                           Grid.Column="1"
                           FontSize="16"
                           Foreground="#FFCCCCCC"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>

            <!-- ВЕРХНЯЯ ПАНЕЛЬ: ОЛИМПИАДЫ И АКТИВНАЯ ГРУППА -->
            <Grid Grid.Row="1" Grid.Column="0"
                  Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ФРЕЙМ ОЛИМПИАДЫ (АДАПТИВНЫЙ) -->
                <Border Grid.Column="0"
                        Background="{StaticResource ReportFrameColor}"
                        CornerRadius="8"
                        Padding="20"
                        Style="{StaticResource HoverFrameStyle}"
                        MinWidth="500"
                        MaxWidth="800">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- БОЛЬШАЯ ЦИФРА -->
                        <TextBlock x:Name="OlimpCountText"
                                   Grid.Row="0" Grid.Column="0"
                                   Text="0"
                                   FontSize="48"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentColor}"
                                   Margin="0,0,30,5"/>

                        <!-- ЗАГОЛОВОК -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="ОЛИМПИАД"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LightTextColor}"
                                   Margin="0,0,30,3"/>

                        <!-- ПОДЗАГОЛОВОК -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="за текущий месяц"
                                   FontSize="12"
                                   Foreground="#FFCCCCCC"
                                   Margin="0,0,30,15"/>

                        <!-- ССЫЛКА -->
                        <TextBlock x:Name="AllOlimpsLink"
                                   Grid.Row="3" Grid.Column="0"
                                   Text="Все олимпиады →"
                                   Style="{StaticResource LinkTextStyle}"
                                   MouseLeftButtonDown="AllOlimpsLink_MouseLeftButtonDown"
                                   VerticalAlignment="Top"
                                   Margin="0,0,30,0"/>

                        <!-- ГРАФИК -->
                        <Border Grid.Row="0" Grid.Column="1"
                                Grid.RowSpan="4"
                                Margin="0,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- ОСНОВНОЙ ГРАФИК -->
                                <Border Grid.Row="0" 
                                        Height="120"
                                        VerticalAlignment="Center">
                                    <Grid x:Name="BarChartGrid"
                                          HorizontalAlignment="Center">
                                        <!-- Столбцы будут добавляться динамически -->
                                    </Grid>
                                </Border>

                                <!-- ЛЕГЕНДА МЕСЯЦЕВ -->
                                <StackPanel x:Name="MonthLegendPanel"
                                            Grid.Row="1"
                                            Style="{StaticResource MonthLegendStyle}"
                                            HorizontalAlignment="Center">
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ФРЕЙМ АКТИВНАЯ ГРУППА -->
                <Border Grid.Column="2"
                        Background="{StaticResource ReportFrameColor}"
                        CornerRadius="8"
                        Padding="20"
                        Style="{StaticResource HoverFrameStyle}"
                        Width="200"
                        Height="200">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Самая активная группа"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LightTextColor}"
                                   Margin="0,0,0,15"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="ActiveGroupText"
                                   Text="T-291"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentColor}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- НИЖНЯЯ ПАНЕЛЬ: ТАБЛИЦА -->
            <Border Grid.Row="2" Grid.Column="0"
                    Background="{StaticResource ReportFrameColor}"
                    CornerRadius="8"
                    Padding="0"
                    Style="{StaticResource HoverFrameStyle}"
                    Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ЗАГОЛОВОК ТАБЛИЦЫ -->
                    <Border Grid.Row="0"
                            Background="Transparent"
                            CornerRadius="8,8,0,0"
                            Padding="15,15,15,10">
                        <TextBlock Text="Рейтинговая таблица"
                                   Style="{StaticResource FrameTitleStyle}"/>
                    </Border>

                    <!-- ТАБЛИЦА -->
                    <DataGrid x:Name="RatingDataGrid"
                              Grid.Row="1"
                              Style="{StaticResource HonorBoardTableStyle}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Margin="10,0"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              RowHeight="40"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" 
                                                Binding="{Binding Position}"
                                                Width="40"/>
                            <DataGridTextColumn Header="ФИО" 
                                                Binding="{Binding FullName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Кол-во олимпиад" 
                                                Binding="{Binding OlimpCount}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Курс" 
                                                Binding="{Binding Course}"
                                                Width="60"/>
                            <DataGridTextColumn Header="Группа" 
                                                Binding="{Binding Group}"
                                                Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- ССЫЛКА -->
                    <Border Grid.Row="2"
                            Background="Transparent"
                            CornerRadius="0,0,8,8"
                            Padding="15,10,15,15">
                        <TextBlock x:Name="AllStudentsLink"
                                   Text="Все учащиеся →"
                                   Style="{StaticResource LinkTextStyle}"
                                   HorizontalAlignment="Left"
                                   MouseLeftButtonDown="AllStudentsLink_MouseLeftButtonDown"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ПРАВАЯ ПАНЕЛЬ: СПЕЦИАЛЬНОСТИ -->
            <Border Grid.Row="1" Grid.Column="2"
        Grid.RowSpan="2"
        Background="{StaticResource ReportFrameColor}"
        CornerRadius="8"
        Padding="15"
        Style="{StaticResource HoverFrameStyle}"
        Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="280"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ЗАГОЛОВОК -->
                    <TextBlock Grid.Row="0"
                   Text="Специальности"
                   Style="{StaticResource FrameTitleStyle}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"
                   FontSize="16"/>

                    <!-- КРУГОВАЯ ДИАГРАММА -->
                    <Border Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,0,0,10">
                        <Canvas x:Name="PieChartCanvas" 
                    Width="280" 
                    Height="280"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
                    </Border>

                    <!-- ЛЕГЕНДА -->
                    <Border Grid.Row="2"
                BorderThickness="0"
                Padding="5"
                Margin="0,5,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="600"
                          VerticalAlignment="Top">
                            <StackPanel x:Name="SpecializationLegend"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>